#!/bin/bash
# Regenerate OmarchyIcons user theme with a custom folder color.
# Usage: omarchy-icons-apply-color #RRGGBB

COLOR="${1}"
if [[ ! "$COLOR" =~ ^#[0-9a-fA-F]{6}$ ]]; then
    echo "omarchy-icons-apply-color: invalid color '$COLOR'" >&2
    exit 1
fi

THEME_DIR="$HOME/.local/share/icons/OmarchyIcons"
SOURCE="/usr/share/icons/Papirus-Dark"

# Papirus grey palette values to replace
OLD_MAIN="#8e8e8e"
OLD_DARK="#727272"
OLD_LIGHT="#e4e4e4"
OLD_GLYPH="#323232"

hex="${COLOR#'#'}"
R=$(( 16#${hex:0:2} ))
G=$(( 16#${hex:2:2} ))
B=$(( 16#${hex:4:2} ))

# Shadow: 80% brightness — folder base/underside
NEW_DARK=$(printf "#%02x%02x%02x" $(( R*4/5 )) $(( G*4/5 )) $(( B*4/5 )))

# Perceived luminance (0-255)
LUMINANCE=$(( (R*299 + G*587 + B*114) / 1000 ))

if (( LUMINANCE > 128 )); then
    # Light folder: blend tab and glyph toward black for inset contrast
    NEW_LIGHT=$(printf "#%02x%02x%02x" $(( R*3/4 )) $(( G*3/4 )) $(( B*3/4 )))
    NEW_GLYPH=$(printf "#%02x%02x%02x" $(( R/2 )) $(( G/2 )) $(( B/2 )))
else
    # Dark folder: blend tab and glyph toward white for inset contrast
    NEW_LIGHT=$(printf "#%02x%02x%02x" \
        $(( R + (255-R)*2/5 )) \
        $(( G + (255-G)*2/5 )) \
        $(( B + (255-B)*2/5 )))
    NEW_GLYPH=$(printf "#%02x%02x%02x" \
        $(( R + (255-R)/4 )) \
        $(( G + (255-G)/4 )) \
        $(( B + (255-B)/4 )))
fi

# Rebuild theme directory from scratch
rm -rf "$THEME_DIR"
mkdir -p "$THEME_DIR"

cat > "$THEME_DIR/index.theme" << 'EOF'
[Icon Theme]
Name=OmarchyIcons
Comment=Omarchy theme-aware folder icons
Inherits=Papirus-Dark
Directories=16x16/places,22x22/places,24x24/places,32x32/places,48x48/places,64x64/places

[16x16/places]
Size=16
Type=Fixed

[22x22/places]
Size=22
Type=Fixed

[24x24/places]
Size=24
Type=Fixed

[32x32/places]
Size=32
Type=Fixed

[48x48/places]
Size=48
Type=Fixed

[64x64/places]
Size=64
Type=Fixed
EOF

for size in 16x16 22x22 24x24 32x32 48x48 64x64; do
    src_dir="$SOURCE/$size/places"
    dst_dir="$THEME_DIR/$size/places"
    [ -d "$src_dir" ] || continue
    mkdir -p "$dst_dir"

    # Copy and recolor actual grey folder SVG files (not symlinks)
    find "$src_dir" -name "folder-grey*.svg" ! -type l | while read svg; do
        newname="$(basename "$svg" | sed 's/folder-grey/folder-omarchy/')"
        sed -e "s/$OLD_MAIN/$COLOR/g" \
            -e "s/$OLD_DARK/$NEW_DARK/g" \
            -e "s/$OLD_LIGHT/$NEW_LIGHT/g" \
            -e "s/$OLD_GLYPH/$NEW_GLYPH/g" \
            "$svg" > "$dst_dir/$newname"
    done

    # Recreate symlinks that pointed to grey variants -> now point to omarchy variants
    find "$src_dir" -name "folder*.svg" -type l | while read lnk; do
        target="$(readlink "$lnk")"
        if [[ "$target" == folder-grey* ]]; then
            new_target="${target/folder-grey/folder-omarchy}"
            ln -sf "$new_target" "$dst_dir/$(basename "$lnk")"
        fi
    done
done

gtk-update-icon-cache -f -t "$THEME_DIR" 2>/dev/null || true

# Toggle to force GTK apps to reload the theme
gsettings set org.gnome.desktop.interface icon-theme "Papirus-Dark"
gsettings set org.gnome.desktop.interface icon-theme "OmarchyIcons"

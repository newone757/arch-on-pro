#!/usr/bin/env python3
"""Serves ~/.config/omarchy/current/spotify-theme.json on localhost for Violentmonkey."""

import json
import os
import sys
from http.server import BaseHTTPRequestHandler, HTTPServer

PORT = 7842
THEME_FILE = os.path.expanduser('~/.config/omarchy/current/spotify-theme.json')


class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        try:
            with open(THEME_FILE) as f:
                data = f.read().encode()
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.send_header('Access-Control-Allow-Origin', '*')
            self.send_header('Cache-Control', 'no-cache')
            self.end_headers()
            self.wfile.write(data)
        except FileNotFoundError:
            self.send_response(404)
            self.end_headers()

    def log_message(self, *_):
        pass  # stay silent


print(f'omarchy-theme-server: listening on localhost:{PORT}', flush=True)
try:
    HTTPServer(('127.0.0.1', PORT), Handler).serve_forever()
except KeyboardInterrupt:
    sys.exit(0)

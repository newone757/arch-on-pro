#!/usr/bin/env python3
"""Serves Omarchy theme as CSS and JSON on localhost for Violentmonkey/Stylus."""

import json
import math
import os
import sys
from http.server import BaseHTTPRequestHandler, HTTPServer

PORT = 7842
THEME_FILE = os.path.expanduser('~/.config/omarchy/current/spotify-theme.json')


def rgb(h):
    h = h.lstrip('#')
    return int(h[:2], 16), int(h[2:4], 16), int(h[4:], 16)


def hue_of(hex_color):
    r, g, b = [x / 255 for x in rgb(hex_color)]
    mx, mn = max(r, g, b), min(r, g, b)
    delta = mx - mn
    if delta == 0:
        return 0
    if mx == r:
        h = ((g - b) / delta) % 6
    elif mx == g:
        h = (b - r) / delta + 2
    else:
        h = (r - g) / delta + 4
    return round(h * 60)


def build_css(c):
    bg    = c['background_base']
    bgh   = c['background_highlight']
    bge   = c['background_elevated_base']
    bgeh  = c['background_elevated_highlight']
    fg    = c['text_base']
    fgs   = c['text_subdued']
    acc   = c['accent']
    pos   = c['positive']
    neg   = c['negative']

    return f"""\
/* Omarchy Spotify Theme — auto-generated, do not edit */

/* ── Design tokens ──────────────────────────────────────────── */
.encore-dark-theme,
.encore-dark-theme .encore-base-set,
:root {{
  --background-base:               {bg}   !important;
  --background-highlight:          {bgh}  !important;
  --background-press:              {c['background_press']} !important;
  --background-elevated-base:      {bge}  !important;
  --background-elevated-highlight: {bgeh} !important;
  --background-tinted-base:        {c['background_tinted_base']} !important;
  --background-tinted-highlight:   {c['background_tinted_highlight']} !important;
  --text-base:                     {fg}   !important;
  --text-subdued:                  {fgs}  !important;
  --text-bright-accent:            {acc}  !important;
  --essential-base:                {fg}   !important;
  --essential-subdued:             {fgs}  !important;
  --essential-bright-accent:       {acc}  !important;
  --essential-positive:            {pos}  !important;
  --essential-negative:            {neg}  !important;
  --decorative-base:               {c['decorative_base']} !important;
  --decorative-subdued:            {c['decorative_subdued']} !important;
}}

/* ── Layout areas ────────────────────────────────────────────── */
/* Sidebar */
[data-testid="left-sidebar"],
[data-testid="left-sidebar"] > * {{
  background-color: {bg} !important;
}}

/* Top navigation bar */
[data-testid="topbar"],
header[aria-label] {{
  background-color: {bg} !important;
}}

/* Now-playing bar */
[data-testid="now-playing-bar"],
footer[aria-label],
.Root__now-playing-bar {{
  background-color: {bge} !important;
  border-top: 1px solid {bgh} !important;
}}

/* Main scrollable view */
[data-testid="main-view-container"],
.main-view-container,
.main-view-container__scroll-node-child-spacer {{
  background-color: {bg} !important;
}}

/* Page header gradient — replace Spotify's dynamic colour with ours */
[data-testid="background-color"],
.x-categoryCard-CardBackground,
.contentSpacing {{
  background-color: {bg} !important;
}}

/* ── Cards & rows ────────────────────────────────────────────── */
[data-testid$="-card"],
.main-card-card {{
  background-color: {bge} !important;
}}
[data-testid$="-card"]:hover,
.main-card-card:hover {{
  background-color: {bgeh} !important;
}}
[data-testid="tracklist-row"]:hover {{
  background-color: {bgh} !important;
}}

/* ── Progress bar fill ───────────────────────────────────────── */
/* Directly colour the filled portion regardless of which variable it reads */
[data-testid="playback-progressbar"] [style*="width"],
[data-testid="playback-progressbar"] [style*="transform"] {{
  background-color: {acc} !important;
}}

/* ── Active / selected accents ───────────────────────────────── */
[data-testid="now-playing-widget"] [aria-label] span,
[class*="activeindicator" i] {{
  color: {acc} !important;
  fill: {acc} !important;
}}
"""


class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        try:
            with open(THEME_FILE) as f:
                colors = json.load(f)

            if self.path == '/spotify.css':
                body = build_css(colors).encode()
                content_type = 'text/css'
            else:
                body = json.dumps(colors, indent=2).encode()
                content_type = 'application/json'

            self.send_response(200)
            self.send_header('Content-Type', content_type)
            self.send_header('Access-Control-Allow-Origin', '*')
            self.send_header('Cache-Control', 'no-cache')
            self.end_headers()
            self.wfile.write(body)
        except FileNotFoundError:
            self.send_response(404)
            self.end_headers()

    def log_message(self, *_):
        pass


print(f'omarchy-theme-server: listening on localhost:{PORT}', flush=True)
try:
    HTTPServer(('127.0.0.1', PORT), Handler).serve_forever()
except KeyboardInterrupt:
    sys.exit(0)

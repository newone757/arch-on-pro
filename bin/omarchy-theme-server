#!/usr/bin/env python3
"""Serves Omarchy theme as CSS and JSON on localhost for Violentmonkey/Stylus."""

import json
import math
import os
import sys
from http.server import BaseHTTPRequestHandler, HTTPServer

PORT = 7842
THEME_FILE = os.path.expanduser('~/.config/omarchy/current/spotify-theme.json')


def rgb(h):
    h = h.lstrip('#')
    return int(h[:2], 16), int(h[2:4], 16), int(h[4:], 16)


def hue_of(hex_color):
    r, g, b = [x / 255 for x in rgb(hex_color)]
    mx, mn = max(r, g, b), min(r, g, b)
    delta = mx - mn
    if delta == 0:
        return 0
    if mx == r:
        h = ((g - b) / delta) % 6
    elif mx == g:
        h = (b - r) / delta + 2
    else:
        h = (r - g) / delta + 4
    return round(h * 60)


def build_css(c):
    # Semantic mapping mirrors the omarchy-theme-hook Spicetify color.ini approach:
    #   color0  = all background surfaces (main/sidebar/cards/player — flat, cohesive)
    #   color8  = hover/highlight (bright black = subtle lift)
    #   color2  = accent / button-active
    #   color15 = primary text (bright white = foreground)
    #   color7  = subdued text (normal white)
    #   color1  = negative / error
    #   color10 = positive (bright green equivalent)
    bg   = c.get('color0',  c.get('background',  '#121212'))
    hl   = c.get('color8',  '#333333')
    acc  = c.get('color2',  c.get('accent',       '#1db954'))
    text = c.get('color15', c.get('foreground',   '#ffffff'))
    tsub = c.get('color7',  '#aaaaaa')
    neg  = c.get('color1',  '#e22134')
    pos  = c.get('color10', c.get('color2', acc))

    return f"""\
/* Omarchy Spotify Theme — auto-generated, do not edit */

/* ── Design tokens (Spicetify-style flat mapping) ───────────── */
.encore-dark-theme,
.encore-dark-theme .encore-base-set,
:root {{
  --background-base:               {bg}   !important;
  --background-highlight:          {hl}   !important;
  --background-press:              {hl}   !important;
  --background-elevated-base:      {bg}   !important;
  --background-elevated-highlight: {hl}   !important;
  --background-tinted-base:        {bg}   !important;
  --background-tinted-highlight:   {hl}   !important;
  --text-base:                     {text} !important;
  --text-subdued:                  {tsub} !important;
  --text-bright-accent:            {acc}  !important;
  --essential-base:                {text} !important;
  --essential-subdued:             {tsub} !important;
  --essential-bright-accent:       {acc}  !important;
  --essential-positive:            {pos}  !important;
  --essential-negative:            {neg}  !important;
  --decorative-base:               {tsub} !important;
  --decorative-subdued:            {hl}   !important;
}}

/* ── Root background — Spotify sets this directly on html ─────── */
html {{
  background-color: {bg} !important;
}}

/* ── Nav bar (actual testid) ─────────────────────────────────── */
[data-testid="global-nav-bar"] {{
  background-color: {bg} !important;
}}

/* ── Now-playing bar ─────────────────────────────────────────── */
[data-testid="now-playing-bar"] {{
  background-color: {bg} !important;
  border-top: 1px solid {hl} !important;
}}

/* ── Kill Spotify's dynamic album-art header gradient ────────── */
[data-testid="background-color"],
.x-categoryCard-CardBackground {{
  background-color: {bg} !important;
  background-image: none !important;
}}

/* ── Cards: transparent so bg shows through, lift on hover ───── */
[data-testid$="-card"],
.main-card-card {{
  background-color: transparent !important;
}}
[data-testid$="-card"]:hover,
.main-card-card:hover,
[data-testid="tracklist-row"]:hover {{
  background-color: {hl} !important;
}}

/* ── Progress bar ────────────────────────────────────────────── */
/* Fill — already getting our accent via CSS var, but pin it explicitly */
[data-testid="progress-bar"],
[data-testid="volume-bar"] [style*="transform"],
[data-testid="volume-bar"] [style*="width"] {{
  background-color: {acc} !important;
}}
/* Track — replace white overlay with subtle theme colour */
[data-testid="progress-bar-background"] {{
  background-color: {hl} !important;
  opacity: 1 !important;
}}
"""


class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        try:
            with open(THEME_FILE) as f:
                colors = json.load(f)

            if self.path == '/spotify.css':
                body = build_css(colors).encode()
                content_type = 'text/css'
            else:
                body = json.dumps(colors, indent=2).encode()
                content_type = 'application/json'

            self.send_response(200)
            self.send_header('Content-Type', content_type)
            self.send_header('Access-Control-Allow-Origin', '*')
            self.send_header('Cache-Control', 'no-cache')
            self.end_headers()
            self.wfile.write(body)
        except FileNotFoundError:
            self.send_response(404)
            self.end_headers()

    def log_message(self, *_):
        pass


print(f'omarchy-theme-server: listening on localhost:{PORT}', flush=True)
try:
    HTTPServer(('127.0.0.1', PORT), Handler).serve_forever()
except KeyboardInterrupt:
    sys.exit(0)

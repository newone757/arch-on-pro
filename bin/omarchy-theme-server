#!/usr/bin/env python3
"""Serves Omarchy theme as CSS and JSON on localhost for Violentmonkey/Stylus."""

import json
import math
import os
import sys
from http.server import BaseHTTPRequestHandler, HTTPServer

PORT = 7842
THEME_FILE = os.path.expanduser('~/.config/omarchy/current/spotify-theme.json')


def rgb(h):
    h = h.lstrip('#')
    return int(h[:2], 16), int(h[2:4], 16), int(h[4:], 16)


def hue_of(hex_color):
    r, g, b = [x / 255 for x in rgb(hex_color)]
    mx, mn = max(r, g, b), min(r, g, b)
    delta = mx - mn
    if delta == 0:
        return 0
    if mx == r:
        h = ((g - b) / delta) % 6
    elif mx == g:
        h = (b - r) / delta + 2
    else:
        h = (r - g) / delta + 4
    return round(h * 60)


def build_css(c):
    # Hue-rotate to shift Spotify's hardcoded green (#1ed760, hue ~141°)
    # to our accent color.
    hue_rotate = hue_of(c['accent']) - 141

    return f"""\
/* Omarchy Spotify Theme — auto-generated, do not edit */

.encore-dark-theme,
.encore-dark-theme .encore-base-set,
:root {{
  --background-base:               {c['background_base']}              !important;
  --background-highlight:          {c['background_highlight']}         !important;
  --background-press:              {c['background_press']}             !important;
  --background-elevated-base:      {c['background_elevated_base']}     !important;
  --background-elevated-highlight: {c['background_elevated_highlight']} !important;
  --background-tinted-base:        {c['background_tinted_base']}       !important;
  --background-tinted-highlight:   {c['background_tinted_highlight']}  !important;
  --text-base:                     {c['text_base']}                    !important;
  --text-subdued:                  {c['text_subdued']}                 !important;
  --text-bright-accent:            {c['accent']}                       !important;
  --essential-bright-accent:       {c['accent']}                       !important;
  --essential-positive:            {c['positive']}                     !important;
  --essential-negative:            {c['negative']}                     !important;
  --decorative-base:               {c['decorative_base']}              !important;
  --decorative-subdued:            {c['decorative_subdued']}           !important;
}}

/* Shift hardcoded Spotify green to our accent hue */
[data-testid="playback-progressbar"] [class],
[data-testid="now-playing-widget"] [class]:not([data-testid]),
[aria-checked="true"] svg,
[class*="activeindicator" i],
[class*="NowPlaying" i] [class] {{
  filter: hue-rotate({hue_rotate}deg) !important;
}}
"""


class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        try:
            with open(THEME_FILE) as f:
                colors = json.load(f)

            if self.path == '/spotify.css':
                body = build_css(colors).encode()
                content_type = 'text/css'
            else:
                body = json.dumps(colors, indent=2).encode()
                content_type = 'application/json'

            self.send_response(200)
            self.send_header('Content-Type', content_type)
            self.send_header('Access-Control-Allow-Origin', '*')
            self.send_header('Cache-Control', 'no-cache')
            self.end_headers()
            self.wfile.write(body)
        except FileNotFoundError:
            self.send_response(404)
            self.end_headers()

    def log_message(self, *_):
        pass


print(f'omarchy-theme-server: listening on localhost:{PORT}', flush=True)
try:
    HTTPServer(('127.0.0.1', PORT), Handler).serve_forever()
except KeyboardInterrupt:
    sys.exit(0)

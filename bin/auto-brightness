#!/usr/bin/env python3
"""
auto-brightness — Ambient Light Sensor auto-brightness for Asahi Linux / Hyprland

Reads lux from IIO sysfs and controls display + keyboard brightness via brightnessctl.
Eased ramping respects manual slider changes on the display; keyboard always auto.
"""

import glob
import os
import signal
import subprocess
import sys
import time

def notify(summary, body="", urgency="low", timeout=2500):
    try:
        subprocess.Popen(
            ["notify-send", "-u", urgency, "-t", str(timeout),
             "-a", "auto-brightness", "-i", "display-brightness",
             summary] + ([body] if body else []),
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
        )
    except Exception:
        pass

# ---------------------------------------------------------------------------
# Tuning — display
# ---------------------------------------------------------------------------

POLL_INTERVAL      = 0.1    # seconds between sensor reads
SMOOTH_STEP_MAX    = 6      # max display units per cycle (eased, out of 500)

LUX_CHANGE_PCT     = 75     # % lux change to resume after manual override
LUX_CHANGE_MIN     = 5      # absolute lux floor for low-light override detection

MIN_BRIGHTNESS     = 10     # display floor (raw units)

# Lux → display brightness % curve (linearly interpolated)
LUX_CURVE = [
    (0,     2),
    (1,     3),
    (5,     6),
    (20,   12),
    (50,   24),
    (100,  40),
    (200,  60),
    (400,  80),
    (700,  92),
    (1000, 100),
]

# ---------------------------------------------------------------------------
# Tuning — keyboard backlight
# ---------------------------------------------------------------------------

KB_SMOOTH_STEP_MAX = 3      # max kbd units per cycle (out of 255)
KB_MIN_BRIGHTNESS  = 0      # kbd floor (can go dark)

# Lux → keyboard brightness % curve
# Stays dim in normal/indoor light, ramps up only in very bright environments
# so keys remain visible when ambient light washes them out.
KB_CURVE = [
    (0,    3),
    (100,  3),
    (300,  5),
    (500,  12),
    (700,  22),
    (1000, 35),
]

# ---------------------------------------------------------------------------
# Sensor
# ---------------------------------------------------------------------------

def find_sensor():
    for dev in sorted(glob.glob("/sys/bus/iio/devices/iio:device*")):
        lux_file = os.path.join(dev, "in_illuminance_input")
        if os.path.exists(lux_file):
            name = ""
            try:
                with open(os.path.join(dev, "name")) as f:
                    name = f.read().strip()
            except Exception:
                pass
            return lux_file, name
    return None, None

def read_lux(sensor_file):
    try:
        with open(sensor_file) as f:
            return int(f.read().strip())
    except Exception:
        return None

# ---------------------------------------------------------------------------
# Display brightness (brightnessctl, device auto-selected)
# ---------------------------------------------------------------------------

def brightness_max():
    try:
        return int(subprocess.check_output(["brightnessctl", "max"], text=True).strip())
    except Exception:
        return 500

def brightness_get():
    try:
        return int(subprocess.check_output(["brightnessctl", "get"], text=True).strip())
    except Exception:
        return None

def brightness_set(val, max_val):
    val = max(MIN_BRIGHTNESS, min(int(val), max_val))
    try:
        subprocess.run(["brightnessctl", "set", str(val)], capture_output=True)
    except Exception:
        pass

# ---------------------------------------------------------------------------
# Keyboard backlight (brightnessctl -d kbd_backlight)
# ---------------------------------------------------------------------------

def kb_max():
    try:
        return int(subprocess.check_output(
            ["brightnessctl", "-d", "kbd_backlight", "max"], text=True).strip())
    except Exception:
        return 255

def kb_get():
    try:
        return int(subprocess.check_output(
            ["brightnessctl", "-d", "kbd_backlight", "get"], text=True).strip())
    except Exception:
        return None

def kb_set(val, max_val):
    val = max(KB_MIN_BRIGHTNESS, min(int(val), max_val))
    try:
        subprocess.run(
            ["brightnessctl", "-d", "kbd_backlight", "set", str(val)],
            capture_output=True
        )
    except Exception:
        pass

# ---------------------------------------------------------------------------
# Lux → brightness mapping (shared for display and keyboard)
# ---------------------------------------------------------------------------

def lux_to_target(lux, curve, max_val, floor):
    if lux <= curve[0][0]:
        pct = curve[0][1]
    elif lux >= curve[-1][0]:
        pct = curve[-1][1]
    else:
        pct = curve[0][1]
        for i in range(len(curve) - 1):
            l0, b0 = curve[i]
            l1, b1 = curve[i + 1]
            if l0 <= lux <= l1:
                t = (lux - l0) / (l1 - l0)
                pct = b0 + t * (b1 - b0)
                break
    return max(floor, min(max_val, int(round(pct / 100.0 * max_val))))

# ---------------------------------------------------------------------------
# Eased step — fast when far, smooth near target
# ---------------------------------------------------------------------------

def eased_step(current, target, step_max):
    distance = abs(target - current)
    step = max(1, min(step_max, distance // 6))
    if current < target:
        return min(current + step, target)
    else:
        return max(current - step, target)

# ---------------------------------------------------------------------------
# Manual override detection (display only)
# ---------------------------------------------------------------------------

def lux_changed_enough(current_lux, override_lux):
    delta = abs(current_lux - override_lux)
    if delta < LUX_CHANGE_MIN:
        return False
    if override_lux == 0:
        return True
    return (delta * 100 / override_lux) >= LUX_CHANGE_PCT

# ---------------------------------------------------------------------------
# Main loop
# ---------------------------------------------------------------------------

def main():
    sensor_file, sensor_name = find_sensor()
    if sensor_file is None:
        print("auto-brightness: no IIO illuminance sensor found", flush=True)
        sys.exit(1)
    print(f"auto-brightness: sensor '{sensor_name}' at {sensor_file}", flush=True)

    disp_max = brightness_max()
    disp_cur = brightness_get()
    if disp_cur is None:
        print("auto-brightness: cannot read brightness, exiting", flush=True)
        sys.exit(1)

    kb_max_val = kb_max()
    kb_cur     = kb_get() or 0
    kb_avail   = kb_get() is not None

    print(f"auto-brightness: display max={disp_max}, kb max={kb_max_val}, "
          f"poll={POLL_INTERVAL}s", flush=True)
    notify("Auto-brightness active")

    signal.signal(signal.SIGTERM, lambda *_: sys.exit(0))
    signal.signal(signal.SIGINT,  lambda *_: sys.exit(0))

    last_set        = disp_cur
    manual_override = False
    override_lux    = 0
    idle_cycles     = 0

    while True:
        time.sleep(POLL_INTERVAL)

        lux = read_lux(sensor_file)
        if lux is None:
            continue

        disp_target = lux_to_target(lux, LUX_CURVE, disp_max, MIN_BRIGHTNESS)

        # Manual override detection (display only) — check when stable at target
        if idle_cycles >= 8:
            actual = brightness_get()
            if actual is not None and abs(actual - last_set) > SMOOTH_STEP_MAX * 3:
                if not manual_override:
                    print(f"auto-brightness: manual override "
                          f"(ours={last_set}, actual={actual})", flush=True)
                    notify("Brightness: manual", "Auto-brightness paused")
                manual_override = True
                override_lux    = lux
                disp_cur        = actual
                last_set        = actual
                idle_cycles     = 0

        if manual_override:
            if lux_changed_enough(lux, override_lux):
                actual = brightness_get()
                if actual is not None:
                    disp_cur = actual
                    last_set = actual
                manual_override = False
                print(f"auto-brightness: resuming (lux {override_lux}->{lux})", flush=True)
                notify("Brightness: auto")
            else:
                # Still step keyboard even during display override
                if kb_avail:
                    kb_target = lux_to_target(lux, KB_CURVE, kb_max_val, KB_MIN_BRIGHTNESS)
                    if kb_cur != kb_target:
                        kb_cur = eased_step(kb_cur, kb_target, KB_SMOOTH_STEP_MAX)
                        kb_set(kb_cur, kb_max_val)
                continue

        # Step display
        if disp_cur != disp_target:
            idle_cycles = 0
            disp_cur    = eased_step(disp_cur, disp_target, SMOOTH_STEP_MAX)
            brightness_set(disp_cur, disp_max)
            last_set = disp_cur
        else:
            idle_cycles = min(idle_cycles + 1, 100)

        # Step keyboard
        if kb_avail:
            kb_target = lux_to_target(lux, KB_CURVE, kb_max_val, KB_MIN_BRIGHTNESS)
            if kb_cur != kb_target:
                kb_cur = eased_step(kb_cur, kb_target, KB_SMOOTH_STEP_MAX)
                kb_set(kb_cur, kb_max_val)


if __name__ == "__main__":
    main()

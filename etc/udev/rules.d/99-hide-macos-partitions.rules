ENV{ID_PART_ENTRY_DISK}=="259:0", ENV{ID_PART_ENTRY_NUMBER}=="2", ENV{UDISKS_IGNORE}="1"
ENV{ID_PART_ENTRY_DISK}=="259:0", ENV{ID_PART_ENTRY_NUMBER}=="3", ENV{UDISKS_IGNORE}="1"
ENV{ID_PART_ENTRY_DISK}=="259:0", ENV{ID_PART_ENTRY_NUMBER}=="6", ENV{UDISKS_IGNORE}="1"

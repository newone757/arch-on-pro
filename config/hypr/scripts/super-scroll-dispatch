#!/usr/bin/env python3
"""
super-scroll-dispatch: converts Super + two-finger trackpad scroll into
hyprctl dispatches (movefocus l/r for scrolling layout navigation).

When Super is held, exclusively grabs the trackpad so scroll events
don't reach Hyprland window content. Released on Super up.
"""

import threading
import subprocess
import time
import sys
import atexit
import evdev
from evdev import ecodes as e

TRACKPAD_DEV = '/dev/input/event4'
KEYBOARD_DEV = '/dev/input/event1'
SUPER_KEYS   = {125, 126}   # KEY_LEFTMETA, KEY_RIGHTMETA
THRESHOLD    = 25
COOLDOWN     = 0.08
LOG          = '/tmp/super-scroll.log'

_lock        = threading.Lock()
_super_held  = False
_accum       = 0.0
_last_fire   = 0.0
_pad         = None   # shared so keyboard thread can grab/ungrab
_grabbed     = False


def log(msg):
    with open(LOG, 'a') as f:
        f.write(f'{time.monotonic():.2f} {msg}\n')


def set_grab(grab: bool):
    global _grabbed
    if _pad is None:
        return
    if grab and not _grabbed:
        try:
            _pad.grab()
            _grabbed = True
            log('grabbed trackpad')
        except Exception as ex:
            log(f'grab error: {ex}')
    elif not grab and _grabbed:
        try:
            _pad.ungrab()
            _grabbed = False
            log('ungrabbed trackpad')
        except Exception as ex:
            log(f'ungrab error: {ex}')


def watch_keyboard():
    global _super_held
    try:
        kbd = evdev.InputDevice(KEYBOARD_DEV)
        log(f'kbd opened: {kbd.name}')
        for ev in kbd.read_loop():
            if ev.type == e.EV_KEY and ev.code in SUPER_KEYS:
                held = ev.value != 0
                with _lock:
                    _super_held = held
                set_grab(held)
                log(f'super_held={held}')
    except Exception as ex:
        log(f'kbd error: {ex}')


def fire(direction):
    global _accum, _last_fire
    now = time.monotonic()
    with _lock:
        if now - _last_fire < COOLDOWN:
            return
        _last_fire = now
        _accum = 0.0
    log(f'dispatch movefocus {direction}')
    subprocess.Popen(['hyprctl', 'dispatch', 'layoutmsg', f'focus {direction}'])


def watch_scroll():
    global _pad, _accum
    try:
        _pad = evdev.InputDevice(TRACKPAD_DEV)
        log(f'pad opened: {_pad.name}')
    except Exception as ex:
        log(f'pad error: {ex}')
        sys.exit(1)

    atexit.register(lambda: set_grab(False))

    slots        = {}
    cur_slot     = 0
    slot_y_delta = {}

    for ev in _pad.read_loop():
        if ev.type == e.EV_ABS:
            if ev.code == e.ABS_MT_SLOT:
                cur_slot = ev.value
            elif ev.code == e.ABS_MT_TRACKING_ID:
                if ev.value == -1:
                    slots.pop(cur_slot, None)
                else:
                    slots[cur_slot] = {'id': ev.value, 'y': None}
            elif ev.code == e.ABS_MT_POSITION_Y:
                if cur_slot in slots:
                    prev = slots[cur_slot]['y']
                    if prev is not None:
                        slot_y_delta[cur_slot] = ev.value - prev
                    slots[cur_slot]['y'] = ev.value

        elif ev.type == e.EV_SYN and ev.code == e.SYN_REPORT:
            if len(slots) >= 2 and slot_y_delta:
                avg_delta = sum(slot_y_delta.values()) / len(slot_y_delta)
                to_fire = None
                with _lock:
                    if _super_held:
                        _accum += avg_delta
                        if abs(_accum) >= THRESHOLD:
                            to_fire = 'r' if _accum > 0 else 'l'
                    else:
                        _accum = 0.0
                if to_fire:
                    fire(to_fire)
            slot_y_delta.clear()


if __name__ == '__main__':
    open(LOG, 'w').close()
    log('starting')
    t = threading.Thread(target=watch_keyboard, daemon=True)
    t.start()
    watch_scroll()

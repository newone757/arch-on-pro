#!/bin/bash

# Sync stable waybar/border color files after omarchy-theme-set runs.
# Aether calls `omarchy-theme-set aether` when applying a wallpaper,
# which would overwrite our stable files with its extracted colors.
# We skip the update for the aether theme so only real omarchy themes
# change the waybar and border appearance.

THEME_NAME="$1"
OMARCHY_THEMES="$HOME/.local/share/omarchy/themes"
USER_THEMES="$HOME/.config/omarchy/themes"

# Skip if not a real omarchy theme (e.g. called by Aether)
if [[ ! -d "$OMARCHY_THEMES/$THEME_NAME" && ! -d "$USER_THEMES/$THEME_NAME" ]]; then
  exit 0
fi

cp ~/.config/omarchy/current/theme/waybar.css ~/.config/waybar/theme-colors.css
cp ~/.config/omarchy/current/theme/hyprland.conf ~/.config/hypr/theme-border.conf

# Strip sections from theme-border.conf that conflict with user config:
#   - input {}   (user's input.conf handles this)
#   - gestures{} (user's input.conf handles gestures)
#   - layerrule  (syntax varies too much across Hyprland versions)
# Also ensure $activeBorderColor is defined for looknfeel.conf.
python3 << 'PYEOF'
import re, os

f = os.path.expanduser('~/.config/hypr/theme-border.conf')
with open(f) as fp:
    content = fp.read()

def strip_block(text, name):
    lines = text.split('\n')
    out, depth, skip = [], 0, False
    for line in lines:
        s = line.strip()
        if not skip:
            if re.match(r'^' + name + r'\s*\{', s):
                skip = True
                depth = s.count('{') - s.count('}')
            else:
                out.append(line)
        else:
            depth += s.count('{') - s.count('}')
            if depth <= 0:
                skip = False
    return '\n'.join(out)

for block in ('input', 'gestures', 'layerrule'):
    content = strip_block(content, block)

# Also strip single-line directives that don't belong in user config
# or use deprecated syntax (windowrulev2 is deprecated in current Hyprland)
content = '\n'.join(l for l in content.split('\n')
                    if not l.strip().startswith('layerrule')
                    and not l.strip().startswith('windowrulev2'))

# Ensure $activeBorderColor is defined (looknfeel.conf uses it)
if '$activeBorderColor' not in content:
    m = re.search(r'col\.active_border\s*=\s*([^#\n]+)', content)
    val = m.group(1).strip() if m else 'rgba(ffffffaa)'
    content = '$activeBorderColor = ' + val + '\n\n' + content

# Ensure $inactiveBorderColor is defined (looknfeel.conf uses it)
if '$inactiveBorderColor' not in content:
    m = re.search(r'col\.inactive_border\s*=\s*([^#\n]+)', content)
    val = m.group(1).strip() if m else 'rgba(595959aa)'
    content = '$inactiveBorderColor = ' + val + '\n\n' + content

with open(f, 'w') as fp:
    fp.write(content)
PYEOF

pkill -SIGUSR2 waybar
hyprctl reload

# Recolor folder icons:
#   - icons.color present → use it explicitly with OmarchyIcons
#   - icons.theme points to a specific non-OmarchyIcons theme → respect it, skip
#   - no icons.theme or already OmarchyIcons → auto-derive from theme accent
ICONS_COLOR_FILE="$HOME/.config/omarchy/current/theme/icons.color"
ICONS_THEME_FILE="$HOME/.config/omarchy/current/theme/icons.theme"
ICONS_THEME_VAL="$([[ -f $ICONS_THEME_FILE ]] && cat $ICONS_THEME_FILE || echo '')"

if [[ -f "$ICONS_COLOR_FILE" ]]; then
    omarchy-icons-apply-color "$(<$ICONS_COLOR_FILE)"
elif [[ -z "$ICONS_THEME_VAL" || "$ICONS_THEME_VAL" == "OmarchyIcons" || "$THEME_NAME" == "aether" ]]; then
    python3 << 'PYEOF'
import re, subprocess, os

colors_file = os.path.expanduser('~/.config/omarchy/current/theme/colors.toml')
try:
    with open(colors_file) as f:
        content = f.read()

    color_hex = None
    for key in ['accent', 'color5', 'color4', 'foreground']:
        m = re.search(rf'^{key}\s*=\s*"#([0-9a-fA-F]{{6}})"', content, re.MULTILINE)
        if m:
            color_hex = m.group(1)
            break

    if color_hex:
        r, g, b = int(color_hex[0:2], 16), int(color_hex[2:4], 16), int(color_hex[4:6], 16)
        luminance = (r*299 + g*587 + b*114) // 1000

        # Clamp luminance to visible folder range (80-170), preserving hue
        if luminance < 80 and luminance > 0:
            factor = 110 / luminance
            r, g, b = min(255, int(r*factor)), min(255, int(g*factor)), min(255, int(b*factor))
        elif luminance > 170:
            factor = 140 / luminance
            r, g, b = int(r*factor), int(g*factor), int(b*factor)

        subprocess.run(['omarchy-icons-apply-color', f'#{r:02x}{g:02x}{b:02x}'])
except Exception:
    pass
PYEOF
# else: theme has its own icons.theme (e.g. Yaru-purple) — respect it, do nothing
fi

# Generate Spotify theme colors for the Violentmonkey userscript
python3 << 'PYEOF'
import re, os, json

colors_file = os.path.expanduser('~/.config/omarchy/current/theme/colors.toml')
output_file = os.path.expanduser('~/.config/omarchy/current/spotify-theme.json')

def get(content, key, fallback):
    m = re.search(rf'^{key}\s*=\s*"(#[0-9a-fA-F]{{6}})"', content, re.MULTILINE)
    return m.group(1) if m else fallback

def rgb(h):
    h = h.lstrip('#')
    return int(h[:2],16), int(h[2:4],16), int(h[4:],16)

def hex_(r, g, b):
    return f'#{int(r):02x}{int(g):02x}{int(b):02x}'

def lighten(c, t):
    r,g,b = rgb(c)
    return hex_(r+(255-r)*t, g+(255-g)*t, b+(255-b)*t)

def mix(c1, c2, t):
    r1,g1,b1 = rgb(c1); r2,g2,b2 = rgb(c2)
    return hex_(r1*t+r2*(1-t), g1*t+g2*(1-t), b1*t+b2*(1-t))

try:
    # Support both colors.toml (user themes) and alacritty.toml (built-in themes)
    alacritty_file = os.path.join(os.path.dirname(colors_file), 'alacritty.toml')

    if os.path.exists(colors_file):
        with open(colors_file) as f:
            content = f.read()
        bg     = get(content, 'background', '#121212')
        fg     = get(content, 'foreground', '#ffffff')
        accent = get(content, 'accent',     '#1db954')
        palette = {f'color{i}': get(content, f'color{i}', bg if i == 0 else fg) for i in range(16)}
    elif os.path.exists(alacritty_file):
        with open(alacritty_file) as f:
            content = f.read()
        def alac(section, key, fallback):
            import re
            m = re.search(rf'\[colors\.{section}\].*?{key}\s*=\s*"(#[0-9a-fA-F]{{6}})"', content, re.DOTALL)
            return m.group(1) if m else fallback
        bg   = alac('primary', 'background', '#121212')
        fg   = alac('primary', 'foreground', '#ffffff')
        norm = ['black','red','green','yellow','blue','magenta','cyan','white']
        brt  = ['black','red','green','yellow','blue','magenta','cyan','white']
        palette = {}
        for i, n in enumerate(norm):
            palette[f'color{i}']    = alac('normal', n, bg if i == 0 else fg)
        for i, n in enumerate(brt):
            palette[f'color{i+8}']  = alac('bright', n, fg)
        accent = palette.get('color4', '#1db954')
    else:
        raise FileNotFoundError('no colors.toml or alacritty.toml found')

    neg = palette.get('color1', '#e22134')
    pos = palette.get('color10', palette.get('color2', '#1db954'))
    colors = palette

    out = {
        **colors,
        'background':  bg,
        'foreground':  fg,
        'accent':      accent,
    }

    os.makedirs(os.path.dirname(output_file), exist_ok=True)
    with open(output_file, 'w') as f:
        json.dump(out, f, indent=2)
except Exception as e:
    import sys
    print(f'spotify-theme: {e}', file=sys.stderr)
PYEOF

# Generate Zen Browser userChrome.css from current theme colors
python3 << 'PYEOF'
import re, os

theme_dir   = os.path.expanduser('~/.config/omarchy/current/theme')
chrome_dir  = os.path.expanduser('~/.config/zen/wgqgmyn5.Default (twilight)/chrome')
output_file = os.path.join(chrome_dir, 'userChrome.css')

def get_toml(content, key, fallback):
    m = re.search(rf'^{key}\s*=\s*"(#[0-9a-fA-F]{{6}})"', content, re.MULTILINE)
    return m.group(1) if m else fallback

def get_alacritty(content, section, key, fallback):
    m = re.search(rf'\[colors\.{section}\].*?{key}\s*=\s*"(#[0-9a-fA-F]{{6}})"', content, re.DOTALL)
    return m.group(1) if m else fallback

try:
    colors_toml    = os.path.join(theme_dir, 'colors.toml')
    alacritty_toml = os.path.join(theme_dir, 'alacritty.toml')

    if os.path.exists(colors_toml):
        with open(colors_toml) as f:
            content = f.read()
        accent = get_toml(content, 'accent',     '#89b4fa')
        bg     = get_toml(content, 'background', '#1e1e2e')
    elif os.path.exists(alacritty_toml):
        with open(alacritty_toml) as f:
            content = f.read()
        bg     = get_alacritty(content, 'primary', 'background', '#1e1e2e')
        # Use color4 (blue/accent) or color5 (magenta) as accent fallback chain
        accent = (get_alacritty(content, 'normal', 'blue',    '') or
                  get_alacritty(content, 'normal', 'magenta', '') or
                  get_alacritty(content, 'normal', 'cyan',    '') or
                  '#89b4fa')
    else:
        raise FileNotFoundError('no colors.toml or alacritty.toml found')

    sidebar_bg  = f"color-mix(in srgb, {accent} 12%, {bg} 88%)"
    panel_bg    = f"color-mix(in srgb, {accent} 25%, {bg} 75%)"
    urlbar_bg   = f"color-mix(in srgb, {accent} 10%, {bg} 90%)"

    css = f"""/* Omarchy theme — auto-generated, do not edit */
:root {{
    --zen-primary-color: {accent} !important;
    --zen-branding-dark: {bg} !important;
    --zen-main-browser-background: {sidebar_bg} !important;
    --zen-navigator-toolbox-background: {sidebar_bg} !important;
    --zen-colors-primary: {panel_bg} !important;
    --zen-colors-secondary: color-mix(in srgb, {accent} 12%, {bg} 88%) !important;
    --zen-loading-progress-bar-color: {accent} !important;
    --zen-urlbar-background: {urlbar_bg} !important;
    --toolbar-bgcolor: {sidebar_bg} !important;
}}

.zen-browser-generic-background::after,
.zen-browser-generic-background.zen-toolbar-background::after {{
    background: {sidebar_bg} !important;
}}

#navigator-toolbox {{
    background: {sidebar_bg} !important;
}}
"""
    with open(output_file, 'w') as f:
        f.write(css)
except Exception as e:
    import sys
    print(f'zen-theme: {e}', file=sys.stderr)
PYEOF


